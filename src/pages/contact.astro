---
const contactEmail = 'mn@mnhsu.xyz';
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Contact MN Hsu." />
    <title>Contact — MN Hsu</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Noto+Sans+TC:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <div class="page">
      <header class="site-header">
        <a href="/" class="logo">mnhsu</a>
        <nav class="site-nav" aria-label="Primary">
          <a href="/#work">work</a>
          <a href="/#about">about</a>
          <a href="/contact/" class="active">contact</a>
        </nav>
      </header>

      <main class="contact-page">
        <section class="contact-hero">
          <h1>Contact</h1>
          <p>
            這裡不是工作頁面。你可以用這封信找到我。
          </p>
        </section>

        <section class="contact-links" aria-label="Contact links">
          <a class="email-link" href={`mailto:${contactEmail}`}>
            {contactEmail}
          </a>

          <div class="link-row">
            <a
              href="https://github.com/ASTROHSU"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub
            </a>
            <a
              href="https://www.blocktrend.today"
              target="_blank"
              rel="noopener noreferrer"
            >
              Blocktrend
            </a>
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <span>MN Hsu © 2026</span>
      </footer>
    </div>
  </body>
</html>

<style>
  :root {
    --bg: #E1DFD9;
    --ink: #000000;
    --muted: #6a6a66;
  }

  * {
    box-sizing: border-box;
  }

  html {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    font-family: "Space Grotesk", "Noto Sans TC", "PingFang TC",
      "Microsoft JhengHei", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 15px;
    line-height: 1.5;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .page {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    max-width: 1600px;
    margin: 0 auto;
    padding: 36px 60px 60px;
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 120px;
  }

  .logo {
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1;
  }

  .site-nav {
    display: flex;
    gap: 28px;
    font-size: 15px;
  }

  .site-nav a.active {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .contact-page {
    flex: 1;
    width: min(100%, 760px);
    margin: 0 auto;
  }

  .contact-hero {
    margin-bottom: 72px;
  }

  .contact-hero h1 {
    margin: 0 0 28px;
    font-size: clamp(4rem, 8vw, 8rem);
    font-weight: 400;
    line-height: 0.92;
    letter-spacing: -0.04em;
  }

  .contact-hero p {
    max-width: 420px;
    margin: 0;
    color: var(--muted);
    font-size: 17px;
    line-height: 1.8;
  }

  .contact-links {
    display: grid;
    gap: 28px;
  }

  .email-link {
    width: fit-content;
    font-size: clamp(2rem, 5vw, 4.6rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.035em;
  }

  .link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 18px 28px;
    color: var(--muted);
    font-size: 15px;
  }

  .site-footer {
    padding-top: 72px;
    color: var(--muted);
    font-size: 14px;
  }

  @media (max-width: 768px) {
    .page {
      padding: 24px 24px 48px;
    }

    .site-header {
      margin-bottom: 80px;
    }

    .logo {
      font-size: 28px;
    }

    .site-nav {
      gap: 18px;
      font-size: 14px;
    }

    .contact-hero {
      margin-bottom: 56px;
    }

    .email-link {
      font-size: clamp(1.8rem, 9vw, 3.4rem);
    }
  }

  @media (max-width: 480px) {
    .site-nav {
      gap: 14px;
    }

    .contact-hero h1 {
      font-size: 3.8rem;
    }
  }
</style>
