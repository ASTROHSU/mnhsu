---
const projects = [
  {
    href: '/pwc0521/',
    zh: '15 天到 0.01 秒',
    en: '郭美伶談台灣 RWA 代幣化',
    date: '2026.05.21',
    tags: ['RWA', '代幣化', '金融科技', '台灣'],
  },
];

const links = [
  { href: 'https://www.blocktrend.today', label: 'Blocktrend' },
  { href: 'https://github.com/ASTROHSU', label: 'GitHub' },
];

const contactEmail = 'mn@mnhsu.xyz';
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="MN Hsu 的個人頁面，收集活動頁、互動文章、筆記和一些正在成形的網頁實驗。"
    />
    <title>MN Hsu</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Noto+Sans+TC:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <div class="page">
      <header class="site-header">
        <a href="/" class="logo">mnhsu</a>
        <nav class="site-nav" aria-label="Primary">
          <a href="#work" class="active">work</a>
          <a href="#about">about</a>
          <a href={`mailto:${contactEmail}`}>contact</a>
        </nav>
      </header>

      <main>
        <section id="work" class="block">
          <h2 class="block-title">work</h2>
          <div class="work-grid">
            {projects.map((project) => (
              <a href={project.href} class="project">
                <div class="project-title">
                  <span class="zh">{project.zh}</span>
                  <span class="en">{project.en}</span>
                </div>
                <div class="project-detail">
                  <time datetime={project.date.replaceAll('.', '-')}>{project.date}</time>
                </div>
                <div class="project-tags" aria-label="Tags">
                  {project.tags.map((tag) => (
                    <span>#{tag}</span>
                  ))}
                </div>
              </a>
            ))}
          </div>
        </section>

        <section id="about" class="block">
          <h2 class="block-title">about</h2>
          <div class="about-body">
            <p>
              許明恩。這裡放一些暫時還不知道怎麼歸檔的實驗半成品。
            </p>
          </div>

          <div class="pill-row">
            {links.map((link) => (
              <a href={link.href} class="pill" target="_blank" rel="noopener noreferrer">{link.label}</a>
            ))}
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <span>MN Hsu © 2026</span>
      </footer>
    </div>
  </body>
</html>

<style>
  :root {
    --bg: #E1DFD9;
    --ink: #000000;
    --muted: #6a6a66;
    --accent: #3d9e5b;
    --line: rgba(0, 0, 0, 0.18);
  }

  * {
    box-sizing: border-box;
  }

  html {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    font-family: "Space Grotesk", "Noto Sans TC", "PingFang TC",
      "Microsoft JhengHei", -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.5;
  }

  a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  a:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .page {
    max-width: 1600px;
    margin: 0 auto;
    padding: 36px 60px 60px;
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 120px;
  }

  .logo {
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1;
  }

  .site-nav {
    display: flex;
    gap: 28px;
    font-size: 15px;
  }

  .site-nav a.active {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .block {
    margin-bottom: 140px;
  }

  .block-title {
    font-size: 26px;
    font-weight: 700;
    margin: 0 0 80px 0;
    letter-spacing: -0.005em;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 72px 32px;
  }

  .project {
    display: block;
  }

  .project-title {
    font-size: 18px;
    font-weight: 500;
    line-height: 1.35;
    margin-bottom: 10px;
  }

  .project-title .zh,
  .project-title .en {
    display: block;
  }

  .project-detail,
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.01em;
  }

  .project-tags {
    margin-top: 12px;
  }

  .project-tags span {
    color: var(--accent);
  }

  .project:hover {
    text-decoration: none;
  }

  .project:hover .project-title {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .about-body {
    max-width: 540px;
    font-size: 17px;
    line-height: 1.75;
  }

  .about-body p {
    margin: 0 0 1em 0;
  }

  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 48px;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    padding: 11px 26px;
    border: 1.5px solid var(--accent);
    color: var(--accent);
    border-radius: 999px;
    font-weight: 500;
    font-size: 15px;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .pill:hover {
    background: var(--accent);
    color: var(--bg);
    text-decoration: none;
  }

  .site-footer {
    margin-top: 60px;
    padding-top: 36px;
    font-size: 14px;
    color: var(--muted);
  }

  @media (max-width: 1100px) {
    .work-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .page {
      padding: 24px 24px 48px;
    }

    .site-header {
      margin-bottom: 72px;
    }

    .logo {
      font-size: 28px;
    }

    .site-nav {
      gap: 18px;
      font-size: 14px;
    }

    .block {
      margin-bottom: 90px;
    }

    .block-title {
      font-size: 22px;
      margin-bottom: 48px;
    }

    .work-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 48px 20px;
    }
  }

  @media (max-width: 480px) {
    .work-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
