---
const works = [
  {
    href: '/pwc0521/',
    title: '15 天到 0.01 秒',
    subtitle: '郭美伶談台灣 RWA 代幣化',
    meta: 'Interactive article / 2026',
    image: '/assets/pwc0521-thumb.png',
  },
];

const links = [
  { href: 'https://www.blocktrend.today', label: 'Blocktrend' },
  { href: 'https://github.com/ASTROHSU', label: 'GitHub' },
];
---

<!DOCTYPE html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="MN Hsu 的個人頁面，收集活動頁、互動文章、筆記和一些正在成形的網頁實驗。"
    />
    <title>MN Hsu</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="MN Hsu home">MN Hsu</a>
      <button class="menu-button" type="button" aria-expanded="false" aria-controls="site-menu">
        <span></span>
        <span></span>
        <span class="sr-only">Menu</span>
      </button>
    </header>

    <nav class="site-menu" id="site-menu" aria-hidden="true">
      <a href="#work">work</a>
      <a href="#about">about</a>
      {links.map((link) => (
        <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
      ))}
    </nav>

    <main id="page">
      <section class="intro" aria-label="Intro">
        <p class="kicker">personal page / internet notebook</p>
        <h1>科技、金融與敘事的<br />個人工作台。</h1>
      </section>

      <section class="work" id="work">
        <h2>work</h2>
        <div class="work-list">
          {works.map((work) => (
            <a class="work-card" href={work.href}>
              <figure>
                <img src={work.image} alt={`${work.title} - ${work.subtitle}`} loading="lazy" />
              </figure>
              <div class="work-text">
                <p>{work.meta}</p>
                <h3>{work.title}</h3>
                <span>{work.subtitle}</span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <section class="about" id="about">
        <h2>about</h2>
        <p>
          我是 MN Hsu。這裡收集我為活動、文章和研究題目做出的互動頁面，也放一些暫時還不需要被歸檔得太整齊的網頁實驗。
        </p>
      </section>
    </main>

    <footer>
      <p>MN Hsu © 2026</p>
    </footer>

    <script>
      const button = document.querySelector('.menu-button');
      const menu = document.querySelector('.site-menu');

      button?.addEventListener('click', () => {
        const isOpen = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', String(!isOpen));
        menu?.setAttribute('aria-hidden', String(isOpen));
        document.body.classList.toggle('menu-open', !isOpen);
      });

      menu?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          button?.setAttribute('aria-expanded', 'false');
          menu.setAttribute('aria-hidden', 'true');
          document.body.classList.remove('menu-open');
        });
      });
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --paper: #f1efea;
    --ink: #080808;
    --muted: #6d6a64;
    --hairline: rgba(8, 8, 8, 0.12);
    --panel: #ffffff;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: Arial, "Noto Sans TC", sans-serif;
    background: var(--paper);
    color: var(--ink);
    line-height: 1.45;
  }

  body.menu-open {
    overflow: hidden;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 30px clamp(24px, 5vw, 64px);
    mix-blend-mode: multiply;
  }

  .brand {
    font-size: clamp(1.6rem, 3.2vw, 2.35rem);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .menu-button {
    position: relative;
    display: grid;
    gap: 9px;
    width: 42px;
    height: 28px;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
  }

  .menu-button span:not(.sr-only) {
    display: block;
    width: 100%;
    height: 1px;
    background: var(--ink);
    transition: transform 0.24s ease, opacity 0.24s ease;
  }

  .menu-button[aria-expanded="true"] span:first-child {
    transform: translateY(5px) rotate(22deg);
  }

  .menu-button[aria-expanded="true"] span:nth-child(2) {
    transform: translateY(-5px) rotate(-22deg);
  }

  .site-menu {
    position: fixed;
    inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 12px;
    padding: 120px clamp(24px, 5vw, 64px) 48px;
    background: rgba(241, 239, 234, 0.96);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-16px);
    transition: opacity 0.24s ease, transform 0.24s ease;
  }

  .site-menu[aria-hidden="false"] {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .site-menu a {
    width: fit-content;
    font-size: clamp(2.5rem, 8vw, 5.6rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: 0;
  }

  main {
    width: min(100%, 1180px);
    margin: 0 auto;
    padding: 0 clamp(24px, 5vw, 64px);
  }

  .intro {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 78vh;
    padding: 140px 0 80px;
  }

  .kicker {
    margin: 0 0 18px;
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    font-size: clamp(3.3rem, 10vw, 8.5rem);
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: 0;
  }

  .work,
  .about {
    padding: 42px 0 0;
  }

  .work h2,
  .about h2 {
    margin: 0 0 132px;
    font-size: clamp(1.35rem, 2.4vw, 2.1rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: 0;
    text-transform: lowercase;
  }

  .work-list {
    display: grid;
    gap: 86px;
    max-width: 640px;
  }

  .work-card {
    display: block;
  }

  .work-card figure {
    margin: 0;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--panel);
  }

  .work-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.08);
    transform: scale(1.02);
    transition: transform 0.45s ease, filter 0.45s ease;
  }

  .work-card:hover img {
    filter: grayscale(0);
    transform: scale(1.055);
  }

  .work-text {
    padding: 20px 0 0;
  }

  .work-text p {
    margin: 0 0 7px;
    color: var(--muted);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .work-text h3 {
    margin: 0;
    font-size: clamp(1.55rem, 3.6vw, 2.45rem);
    font-weight: 500;
    line-height: 1.18;
    letter-spacing: 0;
  }

  .work-text span {
    display: block;
    margin-top: 5px;
    color: var(--muted);
    font-size: clamp(1rem, 2vw, 1.2rem);
  }

  .about {
    max-width: 740px;
    padding-bottom: 140px;
  }

  .about h2 {
    margin-bottom: 32px;
  }

  .about p {
    margin: 0;
    font-size: clamp(1.4rem, 3vw, 2.3rem);
    font-weight: 500;
    line-height: 1.45;
  }

  footer {
    display: flex;
    justify-content: space-between;
    width: min(100%, 1180px);
    margin: 0 auto;
    padding: 0 clamp(24px, 5vw, 64px) 36px;
    color: var(--muted);
    font-size: 0.86rem;
  }

  footer p {
    margin: 0;
  }

  @media (min-width: 820px) {
    .intro {
      min-height: 86vh;
    }

    .work-list {
      max-width: none;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 44px;
      row-gap: 108px;
    }

    .work-card:nth-child(even) {
      transform: translateY(180px);
    }
  }

  @media (max-width: 640px) {
    .site-header {
      padding: 32px 25px;
    }

    .intro {
      min-height: 72vh;
      padding-bottom: 70px;
    }

    .work h2 {
      margin-bottom: 126px;
    }

    .work-list {
      gap: 60px;
    }
  }
</style>
