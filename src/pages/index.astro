---
const projects = [
  {
    href: '/pwc0521/',
    zh: '15 天到 0.01 秒',
    en: '郭美伶談台灣 RWA 代幣化',
    meta: 'Interactive article / 2026',
  },
  {
    href: 'https://www.blocktrend.today',
    zh: '區塊勢',
    en: 'Blocktrend',
    meta: 'Founder / Newsletter & Podcast / 2017-',
  },
  {
    href: 'https://www.twex.tw',
    zh: '富昇數位',
    en: 'TWEX',
    meta: 'Board Director / Virtual asset exchange',
  },
  {
    href: 'https://fluidkey.com',
    zh: 'Fluidkey',
    en: 'Stealth address wallet',
    meta: 'Advisor / Taiwan market',
  },
  {
    href: 'https://stevechoice.org',
    zh: '兆量富足教育協會',
    en: 'Blockchain education',
    meta: 'Blockchain Advisor',
  },
];

const links = [
  { href: 'https://www.blocktrend.today', label: 'Blocktrend' },
  { href: 'https://github.com/ASTROHSU', label: 'GitHub' },
  { href: 'https://card.mnhsu.xyz', label: 'Namecard' },
];

const recognitions = [
  {
    href: 'https://www.bnext.com.tw',
    title: '數位時代 2025、2026 區塊鏈影響力人物',
    meta: 'Recognition',
  },
  {
    href: 'https://nxbn.ethereum.foundation',
    title: '2024 Ethereum Foundation Devcon Scholar',
    meta: 'Scholar',
  },
];

const publications = [
  {
    href: 'https://bookzone.cwgv.com.tw',
    title: 'Read Write Own',
    meta: '審定',
  },
  {
    href: 'https://www.books.com.tw',
    title: '以太奇襲',
    meta: '推薦序',
  },
  {
    href: 'https://readmoo.com',
    title: '無限風暴',
    meta: '推薦序',
  },
];
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="MN Hsu 的個人頁面，收集活動頁、互動文章、筆記和一些正在成形的網頁實驗。"
    />
    <title>MN Hsu</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Noto+Sans+TC:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <div class="page">
      <header class="site-header">
        <a href="/" class="logo">mnhsu</a>
        <nav class="site-nav" aria-label="Primary">
          <a href="#work" class="active">work</a>
          <a href="#about">about</a>
          <a href="#recognition">recognition</a>
          <a href="/contact/">contact</a>
        </nav>
      </header>

      <main>
        <section id="work" class="block">
          <h2 class="block-title">work</h2>
          <div class="work-grid">
            {projects.map((project) => (
              <a href={project.href} class="project" target={project.href.startsWith('http') ? '_blank' : undefined} rel={project.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
                <div class="project-title">
                  <span class="zh">{project.zh}</span>
                  <span class="en">{project.en}</span>
                </div>
                <div class="project-meta">{project.meta}</div>
              </a>
            ))}
          </div>
        </section>

        <section id="about" class="block">
          <h2 class="block-title">about</h2>
          <div class="about-body">
            <p>
              我是許明恩，區塊勢創辦人，長期關注 Web3、金融科技與科技敘事。區塊勢是臺灣最多人訂閱的 Web3 電子報與 Podcast，累積超過 20,000 位訂閱者。
            </p>
            <p>
              這裡收集我為活動、文章和研究題目做出的互動頁面，也放一些暫時還不需要被歸檔得太整齊的網頁實驗。
            </p>
          </div>

          <div class="pill-row">
            {links.map((link) => (
              <a href={link.href} class="pill" target="_blank" rel="noopener noreferrer">{link.label}</a>
            ))}
          </div>
        </section>

        <section id="recognition" class="block">
          <h2 class="block-title">recognition</h2>
          <div class="list-grid">
            {recognitions.map((item) => (
              <a href={item.href} class="list-item" target="_blank" rel="noopener noreferrer">
                <span>{item.title}</span>
                <small>{item.meta}</small>
              </a>
            ))}
          </div>
        </section>

        <section id="publications" class="block">
          <h2 class="block-title">publications</h2>
          <div class="list-grid">
            {publications.map((item) => (
              <a href={item.href} class="list-item" target="_blank" rel="noopener noreferrer">
                <span>{item.title}</span>
                <small>{item.meta}</small>
              </a>
            ))}
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <span>MN Hsu © 2026</span>
      </footer>
    </div>
  </body>
</html>

<style>
  :root {
    --bg: #E1DFD9;
    --ink: #000000;
    --muted: #6a6a66;
    --accent: #3d9e5b;
    --line: rgba(0, 0, 0, 0.18);
  }

  * {
    box-sizing: border-box;
  }

  html {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    font-family: "Space Grotesk", "Noto Sans TC", "PingFang TC",
      "Microsoft JhengHei", -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.5;
  }

  a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  a:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .page {
    max-width: 1600px;
    margin: 0 auto;
    padding: 36px 60px 60px;
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 120px;
  }

  .logo {
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1;
  }

  .site-nav {
    display: flex;
    gap: 28px;
    font-size: 15px;
  }

  .site-nav a.active {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .block {
    margin-bottom: 140px;
  }

  .block-title {
    font-size: 26px;
    font-weight: 700;
    margin: 0 0 80px 0;
    letter-spacing: -0.005em;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 72px 32px;
  }

  .list-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px 32px;
    max-width: 980px;
  }

  .project {
    display: block;
  }

  .list-item {
    display: grid;
    gap: 10px;
    padding-top: 16px;
    border-top: 1.5px solid var(--line);
  }

  .project-title {
    font-size: 18px;
    font-weight: 500;
    line-height: 1.35;
    margin-bottom: 10px;
  }

  .list-item span {
    font-size: 18px;
    font-weight: 500;
    line-height: 1.35;
  }

  .project-title .zh,
  .project-title .en {
    display: block;
  }

  .project-meta {
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.01em;
  }

  .list-item small {
    color: var(--muted);
    font-size: 13px;
    letter-spacing: 0.01em;
  }

  .project:hover {
    text-decoration: none;
  }

  .list-item:hover {
    text-decoration: none;
  }

  .project:hover .project-title {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .list-item:hover span {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .about-body {
    max-width: 540px;
    font-size: 17px;
    line-height: 1.75;
  }

  .about-body p {
    margin: 0 0 1em 0;
  }

  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 48px;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    padding: 11px 26px;
    border: 1.5px solid var(--accent);
    color: var(--accent);
    border-radius: 999px;
    font-weight: 500;
    font-size: 15px;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .pill:hover {
    background: var(--accent);
    color: var(--bg);
    text-decoration: none;
  }

  .site-footer {
    margin-top: 60px;
    padding-top: 36px;
    font-size: 14px;
    color: var(--muted);
  }

  @media (max-width: 1100px) {
    .work-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .list-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .page {
      padding: 24px 24px 48px;
    }

    .site-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 18px;
      margin-bottom: 72px;
    }

    .logo {
      font-size: 28px;
    }

    .site-nav {
      gap: 18px;
      font-size: 14px;
    }

    .block {
      margin-bottom: 90px;
    }

    .block-title {
      font-size: 22px;
      margin-bottom: 48px;
    }

    .work-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 48px 20px;
    }

    .list-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  @media (max-width: 480px) {
    .work-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
