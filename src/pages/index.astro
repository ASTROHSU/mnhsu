  { id: 'every', label: 'Every', tags: ['Every'] },
  { id: 'blocktrend', label: 'Blocktrend', tags: ['區塊勢', '穩定幣', 'Ethereum', 'Ondo', 'RWA'] },
];

const topicFilters = [
  { id: 'ai', label: 'AI', tags: ['AI', 'Technology', 'Attention API'] },
  { id: 'crypto', label: 'Crypto', tags: ['Crypto', 'Ethereum', 'ETH', '穩定幣', 'RWA', 'Ondo', '代幣化', '股票代幣'] },
  { id: 'startups', label: 'Startups', tags: ['Startups', 'YC', 'Y Combinator', '創業'] },
  { id: 'finance', label: 'Finance', tags: ['Money Stuff', 'Bloomberg', 'BlackRock', '貨幣市場基金', '會計', '金融科技'] },
  { id: 'podcasts', label: 'Podcasts', tags: ['Podcast'] },
  { id: 'taiwan', label: 'Taiwan', tags: ['台灣', '會計', '內控'] },
];

const hasAnyTag = (project, tags) => tags.some((tag) => project.tags.includes(tag));
const sourceFor = (project) => sourceFilters.find((source) => hasAnyTag(project, source.tags)) || { id: 'other', label: 'Other' };
const topicsFor = (project) => topicFilters.filter((topic) => hasAnyTag(project, topic.tags));
const projectsWithFilters = projects.map((project) => {
  const source = sourceFor(project);
  const topics = topicsFor(project);
  return {
    ...project,
    sourceId: source.id,
    sourceLabel: source.label,
    topicIds: topics.map((topic) => topic.id),
  };
});

const contactEmail = 'mn@mnhsu.xyz';
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="mnhsu 放一些暫時還不知道怎麼歸檔的實驗半成品。"
    />
    <title>mnhsu</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Noto+Sans+TC:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <div class="page">
      <header class="site-header">
        <a href="/" class="logo">mnhsu</a>
        <nav class="site-nav" aria-label="Primary">
          <a href="#work" class="active">work</a>
          <a href="#about">about</a>
          <a href={`mailto:${contactEmail}`}>contact</a>
        </nav>
      </header>

      <main>
        <section id="work" class="block">
          <h2 class="block-title">work</h2>
          <div class="filter-panel" aria-label="Work filters">
            <div class="filter-group" aria-label="Source filters">
              <span class="filter-label">source</span>
              <button class="filter-chip active" type="button" data-filter-type="source" data-filter-value="">all</button>
              {sourceFilters.map((source) => (
                <button class="filter-chip" type="button" data-filter-type="source" data-filter-value={source.id}>{source.label}</button>
              ))}
            </div>
            <div class="filter-group" aria-label="Topic filters">
              <span class="filter-label">topic</span>
              <button class="filter-chip active" type="button" data-filter-type="topic" data-filter-value="">all</button>
              {topicFilters.map((topic) => (
                <button class="filter-chip" type="button" data-filter-type="topic" data-filter-value={topic.id}>{topic.label}</button>
              ))}
            </div>
            <div class="filter-status" data-filter-status>{projects.length} items</div>
          </div>
          <div class="work-grid" data-work-grid>
            {projectsWithFilters.map((project) => (
              <a
                href={project.href}
                class="project"
                data-source={project.sourceId}
                data-topics={project.topicIds.join(' ')}
              >
                <div class="project-title">
                  <span class="zh">{project.zh}</span>
                  <span class="en">{project.en}</span>
                </div>
                <div class="project-detail">
                  <time datetime={project.date.replaceAll('.', '-')}>{project.date}</time>
                </div>
                <div class="project-tags" aria-label="Tags">
                  {project.tags.map((tag) => (
                    <span>#{tag}</span>
                  ))}
                </div>
              </a>
            ))}
          </div>
          <p class="empty-state" data-empty-state hidden>沒有符合條件的頁面。</p>
        </section>

        <section id="about" class="block">
          <h2 class="block-title">about</h2>
          <div class="about-body">
            <p>
              這裡放一些暫時還不知道怎麼歸檔的實驗半成品。
            </p>
          </div>

          <div class="pill-row">
            {links.map((link) => (
              <a href={link.href} class="pill" target="_blank" rel="noopener noreferrer">{link.label}</a>
            ))}
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <span>mnhsu © 2026</span>
      </footer>
    </div>
    <script>
      const state = { source: '', topic: '' };
      const projects = [...document.querySelectorAll('.project[data-source]')];
      const status = document.querySelector('[data-filter-status]');
      const emptyState = document.querySelector('[data-empty-state]');

      function updateFilters() {
        let visible = 0;
        for (const project of projects) {
          const sourceMatch = !state.source || project.dataset.source === state.source;
          const topics = (project.dataset.topics || '').split(' ').filter(Boolean);
          const topicMatch = !state.topic || topics.includes(state.topic);
          const show = sourceMatch && topicMatch;
          project.hidden = !show;
          if (show) visible += 1;
        }
        if (status) status.textContent = `${visible} item${visible === 1 ? '' : 's'}`;
        if (emptyState) emptyState.hidden = visible !== 0;
      }

      for (const chip of document.querySelectorAll('.filter-chip')) {
        chip.addEventListener('click', () => {
          const type = chip.dataset.filterType;
          if (!type) return;
          state[type] = chip.dataset.filterValue || '';
          document
            .querySelectorAll(`.filter-chip[data-filter-type="${type}"]`)
            .forEach((item) => item.classList.toggle('active', item === chip));
          updateFilters();
        });
      }
    </script>
  </body>
</html>

<style>
  :root {
    --bg: #E1DFD9;
    --ink: #000000;
    --muted: #6a6a66;
    --accent: #3d9e5b;
    --line: rgba(0, 0, 0, 0.18);
  }

  * {
    box-sizing: border-box;
  }

  html {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    font-family: "Space Grotesk", "Noto Sans TC", "PingFang TC",
      "Microsoft JhengHei", -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.5;
  }

  a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  a:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .page {
    max-width: 1600px;
    margin: 0 auto;
    padding: 36px 60px 60px;
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 120px;
  }

  .logo {
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1;
  }

  .site-nav {
    display: flex;
    gap: 28px;
    font-size: 15px;
  }

  .site-nav a.active {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .block {
    margin-bottom: 140px;
  }

  .block-title {
    font-size: 26px;
    font-weight: 700;
    margin: 0 0 48px 0;
    letter-spacing: -0.005em;
  }

  .filter-panel {
    display: grid;
    gap: 18px;
    margin-bottom: 64px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--line);
  }

  .filter-group {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
  }

  .filter-label {
    min-width: 56px;
    color: var(--muted);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .filter-chip {
    appearance: none;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--ink);
    border-radius: 999px;
    padding: 7px 13px;
    font: inherit;
    font-size: 13px;
    line-height: 1.2;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }

  .filter-chip:hover {
    border-color: var(--accent);
  }

  .filter-chip.active {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--bg);
  }

  .filter-status {
    color: var(--muted);
    font-size: 13px;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 72px 32px;
  }

  .project {
    display: block;
  }

  .project[hidden] {
    display: none;
  }

  .project-title {
    font-size: 18px;
    font-weight: 500;
    line-height: 1.35;
    margin-bottom: 10px;
  }

  .project-title .zh,
  .project-title .en {
    display: block;
  }

  .project-detail,
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.01em;
  }

  .project-tags {
    margin-top: 12px;
  }

  .project-tags span {
    color: var(--accent);
  }

  .project:hover {
    text-decoration: none;
  }

  .project:hover .project-title {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .empty-state {
    margin: 0;
    color: var(--muted);
    font-size: 16px;
  }

  .about-body {
    max-width: 540px;
    font-size: 17px;
    line-height: 1.75;
  }

  .about-body p {
    margin: 0 0 1em 0;
  }

  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 48px;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    padding: 11px 26px;
    border: 1.5px solid var(--accent);
    color: var(--accent);
    border-radius: 999px;
    font-weight: 500;
    font-size: 15px;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .pill:hover {
    background: var(--accent);
    color: var(--bg);
    text-decoration: none;
  }

  .site-footer {
    margin-top: 60px;
    padding-top: 36px;
    font-size: 14px;
    color: var(--muted);
  }

  @media (max-width: 1100px) {
    .work-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .page {
      padding: 24px 24px 48px;
    }

    .site-header {
      margin-bottom: 72px;
    }

    .logo {
      font-size: 28px;
    }

    .site-nav {
      gap: 18px;
      font-size: 14px;
    }

    .block {
      margin-bottom: 90px;
    }

    .block-title {
      font-size: 22px;
      margin-bottom: 32px;
    }

    .filter-panel {
      margin-bottom: 44px;
      gap: 16px;
      padding-bottom: 22px;
    }

    .filter-group {
      align-items: flex-start;
      flex-wrap: nowrap;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 4px;
      -webkit-overflow-scrolling: touch;
    }

    .filter-label {
      position: sticky;
      left: 0;
      z-index: 1;
      background: var(--bg);
      padding: 7px 8px 7px 0;
      min-width: auto;
    }

    .filter-chip {
      flex: 0 0 auto;
    }

    .work-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 48px 20px;
    }
  }

  @media (max-width: 480px) {
    .work-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
