const sourceFilters = [
  { id: 'money-stuff', label: 'Money Stuff', tags: ['Money Stuff', 'Bloomberg'] },
  { id: 'stripe', label: 'Stripe', tags: ['Stripe', 'Cheeky Pint'] },
