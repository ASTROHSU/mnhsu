      </div>
    </button>
    <button class="choice-btn" onclick="choose(1)">
      <div class="emoji">⚖️</div>
      <div>
        <div class="label">先做去偏誤彙總</div>
        <div class="desc">把 click、dwell、share 轉成校正後 reward。</div>
      </div>
    </button>
    <button class="choice-btn" onclick="choose(2)">
      <div class="emoji">🔍</div>
      <div>
        <div class="label">先留探索位置</div>
        <div class="desc">讓被低估的事件有機會被讀者驗證。</div>
      </div>
    </button>
  </div>

  <div class="result-card" id="resultCard">
    <div class="r-badge">你的判斷</div>
    <div class="r-title" id="rTitle"></div>
    <div class="r-desc" id="rDesc"></div>
    <div class="share-row">
      <button class="share-btn tw" id="shareTw">分享到 𝕏</button>
      <button class="share-btn fb" id="shareFb">分享到 Facebook</button>
    </div>
  </div>
</div>

