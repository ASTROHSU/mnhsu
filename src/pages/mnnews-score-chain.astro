<script>
let userChoice = -1;
const labels = ['分數不要掉太快', '事件鏈不要變主題桶', '保留人工審稿空間'];
const results = [
  {
    title: '你在意的是首頁排序的穩定度',
    desc: '新版把時間衰減放慢，並把閱讀行為改成疲勞係數。重要事件還是會讓位，但不會因為被看過幾次就失去存在感。',
    bg: 'var(--terra-light)',
    border: '#DBBFAD'
  },
  {
    title: '你在意的是脈絡不要失真',
    desc: '新版把 story chain、context link 和 topic 分開。讀者看到 child 時，應該知道它是同一件事的下一階段。',
    bg: 'var(--yellow-light)',
    border: '#E4D5B8'
  },
  {
    title: '你在意的是程式不要假裝懂脈絡',
    desc: '新版讓 lexical overlap 只做候選召回。真正的 child 判斷要看 actor、action、object、venue、mechanism 和 phase。',
    bg: 'var(--green-light)',
    border: '#A8D4BC'
  }
];

window.choose = function choose(idx){
  if(userChoice >= 0) return;
  userChoice = idx;
  document.querySelectorAll('.choice-btn').forEach((b, i) => {
    if(i === idx) b.classList.add('selected');
    b.style.cursor = 'default';
  });
  const r = results[idx];
  const card = document.getElementById('resultCard');
  document.getElementById('rTitle').textContent = r.title;
  document.getElementById('rDesc').textContent = r.desc;
  card.style.background = r.bg;
  card.style.borderColor = r.border;
  card.classList.add('show');

  const shareText = `我的觀點：${labels[idx]}。\n\n新鮮勢這次把分數和事件鏈拆開處理：分數回答現在該不該浮上來，parent_id 只代表同一件事接著發展。`;
  document.getElementById('shareTw').onclick = function(){
    window.open('https://twitter.com/intent/tweet?text=' + encodeURIComponent(shareText + '\n\n') + '&url=' + encodeURIComponent(location.href), '_blank');
  };
  document.getElementById('shareFb').onclick = function(){
    window.open('https://www.facebook.com/share.php?u=' + encodeURIComponent(location.href) + '&quote=' + encodeURIComponent(shareText), '_blank');
  };
  setTimeout(() => card.scrollIntoView({ behavior:'smooth', block:'center' }), 100);
};

const observer = new IntersectionObserver((entries) => {
  entries.forEach((entry) => {
    if(entry.isIntersecting){
      entry.target.classList.add('visible');
      observer.unobserve(entry.target);
    }
  });
}, { threshold:0.12 });
document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
</script>
